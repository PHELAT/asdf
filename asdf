#!/usr/bin/env bash

set -euo pipefail

ASDF_HUMAN_VERSION="1.0.0"
ASDF_UPDATE_VERSION="2026051000"
ASDF_REMOTE_BASE_URL_OVERRIDE="${ASDF_REMOTE_BASE_URL:-}"
ASDF_REMOTE_BASE_URL="https://raw.githubusercontent.com/PHELAT/asdf/main"
ASDF_REMOTE_BASE_URL="${ASDF_REMOTE_BASE_URL_OVERRIDE:-$ASDF_REMOTE_BASE_URL}"
ASDF_ANALYTICS_URL_OVERRIDE="${ASDF_ANALYTICS_URL:-}"
ASDF_ANALYTICS_URL="https://asdf-analytics.phelat.workers.dev/event"
ASDF_ANALYTICS_URL="${ASDF_ANALYTICS_URL_OVERRIDE:-$ASDF_ANALYTICS_URL}"

DEFAULT_WORKSPACE="${ASDF_DEFAULT_WORKSPACE:-local}"

usage() {
  cat <<'EOF'
Usage:
  asdf [agent] [workspace] [-- agent-args...]
  asdf [workspace] [-- agent-args...]
  asdf [agent] [workspace] wdid [-- agent-args...]
  asdf wdid [-- agent-args...]
  asdf [agent] [workspace] cd
  asdf [workspace] cd
  asdf cd
  asdf <workspace> rm
  asdf <workspace> fork <new-workspace>
  asdf list
  asdf update
  asdf version
  asdf --version
  asdf --completion bash|zsh
  asdf completion bash|zsh
  asdf help

Examples:
  asdf
  asdf codex
  asdf claude
  asdf codex my-work-space
  asdf codex local
  asdf claude my-work-space -- --dangerously-skip-permissions
  asdf wdid
  asdf codex wdid
  asdf codex my-work-tree wdid
  asdf claude local wdid
  asdf cd
  asdf codex my-work-tree cd
  asdf my-work-tree cd
  asdf my-work-tree rm
  asdf my-work-tree fork my-forked-work-tree
  asdf update
  asdf --version

Agents:
  codex
  claude

Workspaces:
  local                 Use the current Git checkout.
  <name>                Use an existing worktree named <name>, or create one.

Worktree summaries:
  list                  Print worktrees. If a worktree has .wdid.md with an
                        Implementation Summary section, show it below the entry.
                        When stdout is a terminal, render the output as markdown
                        with glow, mdcat, or bat when available.

Version and updates:
  version, --version    Print the installed asdf version.

  update                Check the latest published update build and replace the
                        current asdf executable when a newer build is available.
                        Disable automatic update warnings with
                        ASDF_UPDATE_CHECK=0.

  wdid                  Print .wdid.md from the selected checkout. If it does
                        not exist, run the selected agent headlessly to create
                        it, then print it.

  .wdid.md is cached. Once present, wdid prints it without regenerating.
  Delete .wdid.md and run wdid again to regenerate it.

Change directory:
  cd                    Enter the selected checkout in a new interactive shell.
                        Exit that shell to return to the previous directory.

Remove worktree:
  rm                    Remove the explicitly selected worktree. This requires
                        a named worktree, e.g. asdf my-work-tree rm.

Fork worktree:
  fork <new-workspace>  Create <new-workspace> as a new branch/worktree from
                        the selected worktree's current HEAD, including its
                        uncommitted changes.

Shell completion:
  --completion bash|zsh
  completion bash|zsh
                        Print a shell completion script. Add the eval command
                        for your shell to your shell startup file after asdf is
                        on PATH.

Worktree kickstart:
  jkl                   After creating a named worktree, run a root-level jkl
                        file with bash from the new worktree root. asdf checks
                        the new worktree first, then the source checkout. When
                        forking, this runs after uncommitted changes are
                        copied from the source worktree.

Run this from anywhere inside a Git repository. New worktrees are created next
to the repository's primary checkout at:
  ../<repo-name>-worktrees/<workspace>

Override the worktree container with:
  ASDF_WORKTREE_DIR=/path/to/worktrees asdf codex my-work-space

Other environment overrides:
  ASDF_DEFAULT_AGENT=claude
    When unset, asdf uses codex if installed, otherwise claude.
  ASDF_DEFAULT_WORKSPACE=my-work-space

jkl receives:
  ASDF_JKL_FILE         Path to the jkl file being run.
  ASDF_JKL_SOURCE_DIR   Checkout/worktree used as the source.
  ASDF_JKL_TARGET_DIR   Newly created worktree being set up.
  ASDF_JKL_WORKSPACE    New worktree name.
EOF
}

die() {
  printf 'asdf: %s\n' "$*" >&2
  exit 1
}

print_version() {
  printf 'asdf %s\n' "$ASDF_HUMAN_VERSION"
}

current_executable_path() {
  local source_path source_dir source_base

  source_path="${BASH_SOURCE[0]:-$0}"
  case "$source_path" in
    */*) ;;
    *)
      source_path="$(command -v "$source_path" 2>/dev/null || true)"
      if [ -z "$source_path" ]; then
        source_path="$(command -v "$0" 2>/dev/null || true)"
      fi
      ;;
  esac

  [ -n "$source_path" ] || return 1

  case "$source_path" in
    /*)
      printf '%s\n' "$source_path"
      ;;
    *)
      source_dir="$(dirname "$source_path")" || return 1
      source_base="$(basename "$source_path")" || return 1
      (cd "$source_dir" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$source_base")
      ;;
  esac
}

is_valid_update_version() {
  case "${1:-}" in
    "" | *[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

normalize_update_version() {
  local version="$1"

  while [ "${version#0}" != "$version" ]; do
    version="${version#0}"
  done

  [ -n "$version" ] || version="0"
  printf '%s\n' "$version"
}

update_version_gt() {
  local left right

  is_valid_update_version "$1" || return 1
  is_valid_update_version "$2" || return 1

  left="$(normalize_update_version "$1")"
  right="$(normalize_update_version "$2")"

  if [ "${#left}" -gt "${#right}" ]; then
    return 0
  fi

  if [ "${#left}" -lt "${#right}" ]; then
    return 1
  fi

  [[ "$left" > "$right" ]]
}

fetch_remote_update_version() {
  local raw version url

  url="$ASDF_REMOTE_BASE_URL/version.txt"
  if [ "${1:-}" = "quick" ]; then
    raw="$(curl -fsSL --max-time 2 "$url" 2>/dev/null)" || return 1
  else
    raw="$(curl -fsSL "$url" 2>/dev/null)" || return 1
  fi

  version="${raw%%$'\n'*}"
  version="${version%$'\r'}"
  printf '%s\n' "$version"
}

file_mode() {
  stat -f '%Lp' "$1" 2>/dev/null ||
    stat -c '%a' "$1" 2>/dev/null ||
    printf '755\n'
}

json_string() {
  local value="$1"

  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '"%s"' "$value"
}

send_analytics_event() {
  local event="${1:-}"
  local install_name="${2:-}"
  local conflict_fallback="${3:-false}"
  local current_path os_name shell_name timestamp payload

  [ "${ASDF_ANALYTICS:-1}" != "0" ] || return 0
  command -v curl >/dev/null 2>&1 || return 0

  case "$event" in
    install | update_success | update_failed) ;;
    *) return 0 ;;
  esac

  if [ -z "$install_name" ]; then
    current_path="$(current_executable_path 2>/dev/null || true)"
    if [ -n "$current_path" ]; then
      install_name="$(basename "$current_path")"
    else
      install_name="$(basename "$0")"
    fi
  fi

  case "$conflict_fallback" in
    true | 1 | yes) conflict_fallback="true" ;;
    *) conflict_fallback="false" ;;
  esac

  os_name="$(uname -s 2>/dev/null || printf 'unknown')"
  shell_name="$(basename "${SHELL:-unknown}")"
  timestamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || printf 'unknown')"

  payload="$(printf '{"event":%s,"human_version":%s,"update_version":%s,"install_name":%s,"os":%s,"shell":%s,"conflict_fallback":%s,"timestamp":%s}' \
    "$(json_string "$event")" \
    "$(json_string "$ASDF_HUMAN_VERSION")" \
    "$(json_string "$ASDF_UPDATE_VERSION")" \
    "$(json_string "$install_name")" \
    "$(json_string "$os_name")" \
    "$(json_string "$shell_name")" \
    "$conflict_fallback" \
    "$(json_string "$timestamp")")"

  curl -fsS --max-time 2 \
    -H 'content-type: application/json' \
    -X POST \
    --data "$payload" \
    "$ASDF_ANALYTICS_URL" >/dev/null 2>&1 || true
}

analytics_conflict_fallback_for_name() {
  if [ "${1:-}" = "asdff" ]; then
    printf 'true\n'
  else
    printf 'false\n'
  fi
}

update_failure() {
  local install_name="$1"
  local message="$2"
  local conflict_fallback

  conflict_fallback="$(analytics_conflict_fallback_for_name "$install_name")"
  send_analytics_event "update_failed" "$install_name" "$conflict_fallback"
  die "$message"
}

asdf_update() {
  local install_path install_name install_dir conflict_fallback
  local remote_version tmp_file mode

  [ "$#" -eq 0 ] || die "update does not accept extra arguments"

  install_path="$(current_executable_path)" ||
    update_failure "asdf" "could not resolve current executable path"
  install_name="$(basename "$install_path")"
  conflict_fallback="$(analytics_conflict_fallback_for_name "$install_name")"

  command -v curl >/dev/null 2>&1 ||
    update_failure "$install_name" "curl is required to update asdf"
  command -v bash >/dev/null 2>&1 ||
    update_failure "$install_name" "bash is required to validate updates"

  if ! remote_version="$(fetch_remote_update_version)"; then
    update_failure "$install_name" "could not fetch update version from $ASDF_REMOTE_BASE_URL/version.txt"
  fi

  if ! is_valid_update_version "$remote_version"; then
    update_failure "$install_name" "invalid remote update version '$remote_version'"
  fi

  if ! update_version_gt "$remote_version" "$ASDF_UPDATE_VERSION"; then
    send_analytics_event "update_success" "$install_name" "$conflict_fallback"
    printf 'asdf: already up to date (asdf %s, update %s)\n' "$ASDF_HUMAN_VERSION" "$ASDF_UPDATE_VERSION"
    return 0
  fi

  [ -f "$install_path" ] ||
    update_failure "$install_name" "current executable path is not a file: $install_path"

  install_dir="$(dirname "$install_path")"
  if [ ! -w "$install_path" ] || [ ! -w "$install_dir" ]; then
    update_failure "$install_name" "install path is not writable: $install_path"
  fi

  tmp_file="$(mktemp "$install_dir/.asdf-update.XXXXXX")" ||
    update_failure "$install_name" "could not create a temporary update file in $install_dir"

  if ! curl -fsSL "$ASDF_REMOTE_BASE_URL/asdf" -o "$tmp_file" 2>/dev/null; then
    rm -f "$tmp_file"
    update_failure "$install_name" "could not download updated asdf from $ASDF_REMOTE_BASE_URL/asdf"
  fi

  if ! bash -n "$tmp_file" >/dev/null 2>&1; then
    rm -f "$tmp_file"
    update_failure "$install_name" "downloaded update is not a valid bash script"
  fi

  mode="$(file_mode "$install_path")"
  if ! chmod "$mode" "$tmp_file" >/dev/null 2>&1; then
    rm -f "$tmp_file"
    update_failure "$install_name" "could not preserve executable permissions for $install_path"
  fi

  if ! mv -f "$tmp_file" "$install_path"; then
    rm -f "$tmp_file"
    update_failure "$install_name" "could not replace $install_path"
  fi

  send_analytics_event "update_success" "$install_name" "$conflict_fallback"
  printf 'asdf: updated %s from update %s to %s\n' "$install_path" "$ASDF_UPDATE_VERSION" "$remote_version"
}

maybe_warn_update_available() {
  local cache_base cache_dir cache_file now last age remote_version

  [ "${ASDF_UPDATE_CHECK:-1}" != "0" ] || return 0
  [ -t 2 ] || return 0

  case "${1:-}" in
    --complete | --completion | completion | --version | version | update)
      return 0
      ;;
  esac

  command -v curl >/dev/null 2>&1 || return 0

  if [ -n "${XDG_CACHE_HOME:-}" ]; then
    cache_base="$XDG_CACHE_HOME"
  elif [ -n "${HOME:-}" ]; then
    cache_base="$HOME/.cache"
  else
    return 0
  fi

  now="$(date +%s 2>/dev/null)" || return 0
  is_valid_update_version "$now" || return 0

  cache_dir="$cache_base/asdf"
  cache_file="$cache_dir/last_update_check"
  last="0"

  if [ -r "$cache_file" ]; then
    IFS= read -r last <"$cache_file" || last="0"
  fi

  if is_valid_update_version "$last" && [ "$last" -gt 0 ]; then
    age=$((now - last))
    if [ "$age" -ge 0 ] && [ "$age" -lt 86400 ]; then
      return 0
    fi
  fi

  mkdir -p "$cache_dir" >/dev/null 2>&1 || return 0
  printf '%s\n' "$now" >"$cache_file" 2>/dev/null || return 0

  remote_version="$(fetch_remote_update_version quick || true)"
  is_valid_update_version "$remote_version" || return 0

  if update_version_gt "$remote_version" "$ASDF_UPDATE_VERSION"; then
    printf "asdf: update available; run 'asdf update'\n" >&2
  fi
}

is_supported_agent() {
  case "${1:-}" in
    codex | claude) return 0 ;;
    *) return 1 ;;
  esac
}

is_workspace_command() {
  case "${1:-}" in
    wdid | cd | rm | fork) return 0 ;;
    *) return 1 ;;
  esac
}

emit_matching_candidates() {
  local prefix="$1"
  shift

  local candidate
  for candidate in "$@"; do
    case "$candidate" in
      "$prefix"*) printf '%s\n' "$candidate" ;;
    esac
  done
}

emit_matching_candidate_lines() {
  local prefix="$1"
  local candidate

  while IFS= read -r candidate; do
    case "$candidate" in
      "$prefix"*) printf '%s\n' "$candidate" ;;
    esac
  done
}

completion_workspace_candidates() {
  local current_dir repo_root

  printf 'local\n'

  current_dir="$(pwd -P)"
  repo_root="$(git -C "$current_dir" rev-parse --show-toplevel 2>/dev/null)" ||
    return 0

  git -C "$repo_root" worktree list --porcelain 2>/dev/null |
    awk '
      function basename(path, parts, count) {
        count = split(path, parts, "/")
        return parts[count]
      }

      function branchname(ref) {
        sub(/^refs\/heads\//, "", ref)
        return ref
      }

      function valid(name) {
        return name != "" &&
          name != "local" &&
          name != "wdid" &&
          name != "cd" &&
          name != "rm" &&
          name != "fork" &&
          name != "update" &&
          name != "version" &&
          name !~ /^-/ &&
          name !~ /\// &&
          name !~ /\.\./ &&
          name !~ /[[:space:]]/
      }

      function emit(name) {
        if (valid(name) && !seen[name]++) {
          print name
        }
      }

      function flush() {
        if (path == "") {
          return
        }

        emit(basename(path))
        emit(branchname(branch))
      }

      /^worktree / {
        flush()
        path = substr($0, 10)
        branch = ""
        next
      }

      /^branch / {
        branch = substr($0, 8)
        next
      }

      END {
        flush()
      }
    ' || return 0
}

complete_first_word() {
  local prefix="$1"

  emit_matching_candidates "$prefix" \
    codex claude wdid cd fork list ls update version help --help -h --version --completion completion
  completion_workspace_candidates | emit_matching_candidate_lines "$prefix"
}

complete_workspace_position() {
  local prefix="$1"

  emit_matching_candidates "$prefix" wdid cd fork --
  completion_workspace_candidates | emit_matching_candidate_lines "$prefix"
}

complete_after_workspace() {
  local prefix="$1"

  emit_matching_candidates "$prefix" wdid cd rm fork --
}

complete_asdf_words() {
  local cword="${1:-0}"
  shift || true

  local -a words
  words=("$@")

  local cur first second third i
  cur="${words[$cword]:-}"
  first="${words[1]:-}"
  second="${words[2]:-}"
  third="${words[3]:-}"

  for ((i = 1; i < cword; i++)); do
    [ "${words[$i]:-}" != "--" ] || return 0
  done

  if [ "$cword" -le 1 ]; then
    complete_first_word "$cur"
    return
  fi

  case "$first" in
    --completion | completion)
      if [ "$cword" -eq 2 ]; then
        emit_matching_candidates "$cur" bash zsh
      fi
      return
      ;;
    --help | -h | help | list | ls | cd | update | version | --version)
      return
      ;;
    wdid)
      if [ "$cword" -eq 2 ]; then
        emit_matching_candidates "$cur" --
      fi
      return
      ;;
    fork)
      return
      ;;
  esac

  if is_supported_agent "$first"; then
    case "$cword" in
      2)
        complete_workspace_position "$cur"
        return
        ;;
      3)
        case "$second" in
          wdid)
            emit_matching_candidates "$cur" --
            ;;
          cd | rm | fork)
            ;;
          *)
            complete_after_workspace "$cur"
            ;;
        esac
        return
        ;;
      4)
        if [ "$third" = "wdid" ]; then
          emit_matching_candidates "$cur" --
        fi
        return
        ;;
      *)
        return
        ;;
    esac
  fi

  case "$cword" in
    2)
      complete_after_workspace "$cur"
      ;;
    3)
      if [ "$second" = "wdid" ]; then
        emit_matching_candidates "$cur" --
      fi
      ;;
  esac
}

print_completion_script() {
  local shell="${1:-}"
  local completion_command_name

  [ "$#" -eq 1 ] ||
    die "usage: asdf --completion bash|zsh"

  completion_command_name="$(basename "$0")"

  case "$shell" in
    bash)
      cat <<EOF
_asdf_completion() {
  local completion

  COMPREPLY=()
  while IFS= read -r completion; do
    COMPREPLY+=("\$completion")
  done < <(command "$completion_command_name" --complete "\$COMP_CWORD" "\${COMP_WORDS[@]}")
}

complete -o default -o bashdefault -F _asdf_completion "$completion_command_name"
EOF
      ;;
    zsh)
      cat <<EOF
#compdef $completion_command_name

_asdf_completion_body() {
  local -a completions
  completions=("\${(@f)\$(command "$completion_command_name" --complete "\$((CURRENT - 1))" "\${words[@]}")}")

  if (( \${#completions[@]} )); then
    compadd -- "\${completions[@]}"
  else
    _default
  fi
}

if [[ "\${funcstack[1]:-}" == "_asdf" ]]; then
  _asdf_completion_body "\$@"
else
  if ! whence compdef >/dev/null 2>&1; then
    autoload -Uz compinit
    compinit
  fi

  _asdf_completion() {
    _asdf_completion_body "\$@"
  }

  compdef _asdf_completion "$completion_command_name"
fi
EOF
      ;;
    *)
      die "usage: asdf --completion bash|zsh"
      ;;
  esac
}

resolve_default_agent() {
  if [ "${ASDF_DEFAULT_AGENT+x}" = "x" ]; then
    [ -n "$ASDF_DEFAULT_AGENT" ] ||
      die "ASDF_DEFAULT_AGENT is set but empty; expected one of: codex, claude"

    is_supported_agent "$ASDF_DEFAULT_AGENT" ||
      die "unsupported default agent '$ASDF_DEFAULT_AGENT'"

    printf '%s\n' "$ASDF_DEFAULT_AGENT"
    return
  fi

  if command -v codex >/dev/null 2>&1; then
    printf 'codex\n'
    return
  fi

  if command -v claude >/dev/null 2>&1; then
    printf 'claude\n'
    return
  fi

  die "could not choose a default agent: neither 'codex' nor 'claude' was found in PATH; install one or set ASDF_DEFAULT_AGENT to codex or claude"
}

parse_agent_args() {
  if [ "$#" -eq 0 ]; then
    return
  fi

  [ "$1" = "--" ] ||
    die "unexpected argument '$1'; use -- before arguments intended for $agent_name"

  shift
  agent_args=("$@")
}

parse_no_args() {
  [ "$#" -eq 0 ] ||
    die "'$command_name' does not accept extra arguments"
}

parse_workspace_command() {
  command_name="$1"
  shift

  case "$command_name" in
    wdid)
      [ -n "$agent_name" ] || agent_name="$(resolve_default_agent)"
      parse_agent_args "$@"
      ;;
    cd)
      parse_no_args "$@"
      ;;
    rm)
      parse_no_args "$@"
      ;;
    fork)
      [ "$#" -eq 1 ] ||
        die "fork requires a new worktree name: asdf <worktree> fork <new-worktree>"
      fork_workspace_name="$1"
      ;;
    *)
      die "unknown command '$command_name'"
      ;;
  esac
}

parse_args() {
  local saw_agent=0

  command_name="run"
  agent_name=""
  workspace_name="$DEFAULT_WORKSPACE"
  workspace_explicit=0
  fork_workspace_name=""
  agent_args=()

  if [ "$#" -eq 0 ]; then
    agent_name="$(resolve_default_agent)"
    return
  fi

  case "$1" in
    help | -h | --help)
      usage
      exit 0
      ;;
    list | ls)
      command_name="list"
      return
      ;;
    wdid)
      command_name="wdid"
      agent_name="$(resolve_default_agent)"
      workspace_name="local"
      shift
      parse_agent_args "$@"
      return
      ;;
    cd)
      command_name="cd"
      workspace_name="local"
      shift
      parse_no_args "$@"
      return
      ;;
    rm)
      die "rm requires an explicit worktree name: asdf <worktree> rm"
      ;;
    fork)
      workspace_name="local"
      parse_workspace_command "$@"
      return
      ;;
  esac

  if is_supported_agent "$1"; then
    agent_name="$1"
    saw_agent=1
    shift
  else
    workspace_name="$1"
    workspace_explicit=1
    shift
  fi

  if [ "$#" -gt 0 ] && is_workspace_command "$1"; then
    if [ "$saw_agent" -eq 1 ]; then
      workspace_name="local"
    fi
    parse_workspace_command "$@"
    return
  fi

  if [ "$#" -gt 0 ] && [ "$1" != "--" ]; then
    if [ "$saw_agent" -eq 1 ]; then
      workspace_name="$1"
      workspace_explicit=1
      shift

      if [ "$#" -gt 0 ] && is_workspace_command "$1"; then
        parse_workspace_command "$@"
        return
      fi
    else
      [ -n "$agent_name" ] || agent_name="$(resolve_default_agent)"
      die "unexpected argument '$1'; use -- before arguments intended for $agent_name"
    fi
  fi

  [ -n "$agent_name" ] || agent_name="$(resolve_default_agent)"
  parse_agent_args "$@"
}

find_existing_worktree() {
  local name="$1"

  git -C "$REPO_ROOT" worktree list --porcelain |
    awk -v name="$name" '
      function basename(path, parts, count) {
        count = split(path, parts, "/")
        return parts[count]
      }

      function branchname(ref) {
        sub(/^refs\/heads\//, "", ref)
        return ref
      }

      function flush() {
        if (path == "") {
          return
        }

        if (basename(path) == name || branchname(branch) == name) {
          print path
          found = 1
          exit
        }
      }

      /^worktree / {
        flush()
        path = substr($0, 10)
        branch = ""
        next
      }

      /^branch / {
        branch = substr($0, 8)
        next
      }

      END {
        if (!found) {
          flush()
        }
      }
    '
}

validate_workspace_name() {
  local name="$1"

  [ -n "$name" ] || die "workspace name cannot be empty"
  [ "$name" != "wdid" ] || die "'wdid' is a reserved command name"
  [ "$name" != "cd" ] || die "'cd' is a reserved command name"
  [ "$name" != "rm" ] || die "'rm' is a reserved command name"
  [ "$name" != "fork" ] || die "'fork' is a reserved command name"
  [ "$name" != "update" ] || die "'update' is a reserved command name"
  [ "$name" != "version" ] || die "'version' is a reserved command name"
  [ "$name" != "local" ] || return 0

  case "$name" in
    -*)
      die "workspace '$name' cannot start with '-'"
      ;;
    */* | *..* | *[[:space:]]*)
      die "workspace '$name' must be a simple branch/path name without slashes, '..', or spaces"
      ;;
  esac

  git -C "$REPO_ROOT" check-ref-format --branch "$name" >/dev/null 2>&1 ||
    die "workspace '$name' is not a valid git branch name"
}

run_jkl() {
  local source="$1"
  local target="$2"
  local workspace="$3"
  local target_jkl="$target/jkl"
  local source_jkl="$source/jkl"
  local jkl_file=""

  if [ -e "$target_jkl" ]; then
    [ -f "$target_jkl" ] ||
      die "$target_jkl exists but is not a regular file"
    jkl_file="$target_jkl"
  elif [ "$source" != "$target" ] && [ -e "$source_jkl" ]; then
    [ -f "$source_jkl" ] ||
      die "$source_jkl exists but is not a regular file"
    jkl_file="$source_jkl"
  else
    return 0
  fi

  printf 'asdf: running jkl %s in %s\n' "$jkl_file" "$target" >&2

  if ! (
    cd "$target" || exit 1
    ASDF_JKL_FILE="$jkl_file" \
      ASDF_JKL_SOURCE_DIR="$source" \
      ASDF_JKL_TARGET_DIR="$target" \
      ASDF_JKL_WORKSPACE="$workspace" \
      bash "$jkl_file" >&2
  ); then
    die "jkl failed for worktree '$workspace'"
  fi
}

create_worktree() {
  local name="$1"
  local target="$2"

  mkdir -p "$WORKTREE_ROOT"

  [ ! -e "$target" ] ||
    die "target '$target' already exists but is not registered as a git worktree"

  if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$name"; then
    printf 'asdf: creating worktree %s from existing branch %s\n' "$target" "$name" >&2
    git -C "$REPO_ROOT" worktree add "$target" "$name" >&2
  else
    printf 'asdf: creating worktree %s with new branch %s\n' "$target" "$name" >&2
    git -C "$REPO_ROOT" worktree add -b "$name" "$target" HEAD >&2
  fi

  run_jkl "$REPO_ROOT" "$target" "$name"
}

workspace_path() {
  local name="$1"
  local existing target

  validate_workspace_name "$name"

  if [ "$name" = "local" ]; then
    printf '%s\n' "$REPO_ROOT"
    return
  fi

  existing="$(find_existing_worktree "$name")"
  if [ -n "$existing" ]; then
    printf 'asdf: using existing worktree %s\n' "$existing" >&2
    printf '%s\n' "$existing"
    return
  fi

  target="$WORKTREE_ROOT/$name"
  create_worktree "$name" "$target"
  printf '%s\n' "$target"
}

existing_workspace_path() {
  local name="$1"
  local existing

  validate_workspace_name "$name"

  if [ "$name" = "local" ]; then
    printf '%s\n' "$REPO_ROOT"
    return
  fi

  existing="$(find_existing_worktree "$name")"
  [ -n "$existing" ] ||
    die "worktree '$name' was not found"

  printf '%s\n' "$existing"
}

list_worktrees() {
  local display_output porcelain_output line i list_markdown tmp_root
  local count=0
  local path_count=0
  local -a display_lines paths

  display_output="$(git -C "$REPO_ROOT" worktree list)"
  porcelain_output="$(git -C "$REPO_ROOT" worktree list --porcelain)"

  while IFS= read -r line; do
    if [ -z "$line" ]; then
      continue
    fi

    display_lines[count]="$line"
    count=$((count + 1))
  done <<<"$display_output"

  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        paths[path_count]="${line#worktree }"
        path_count=$((path_count + 1))
        ;;
    esac
  done <<<"$porcelain_output"

  if [ -t 1 ] && has_markdown_renderer; then
    tmp_root="${TMPDIR:-/tmp}"
    tmp_root="${tmp_root%/}"
    list_markdown="$(mktemp "$tmp_root/asdf-list.XXXXXX.md")" ||
      die "could not create temporary list file"

    i=0
    while [ "$i" -lt "$count" ]; do
      printf '%s\n' "${display_lines[$i]}"
      if [ "$i" -lt "$path_count" ]; then
        print_wdid_implementation_summary_markdown "${paths[$i]}/.wdid.md"
      fi
      printf '\n'
      i=$((i + 1))
    done >"$list_markdown"

    if ! render_markdown_file "$list_markdown" never; then
      rm -f "$list_markdown"
      return 1
    fi

    rm -f "$list_markdown"
    return
  fi

  i=0
  while [ "$i" -lt "$count" ]; do
    printf '%s\n' "${display_lines[$i]}"
    if [ "$i" -lt "$path_count" ]; then
      print_wdid_implementation_summary "${paths[$i]}/.wdid.md"
    fi
    i=$((i + 1))
  done
}

extract_wdid_implementation_summary() {
  local wdid_file="$1"

  awk '
    /^##[[:space:]]+Implementation Summary[[:space:]]*#*[[:space:]]*$/ {
      in_section = 1
      saw_heading = 1
      next
    }

    in_section && /^#{1,2}[[:space:]]+/ {
      exit
    }

    in_section {
      lines[++count] = $0
    }

    END {
      if (!saw_heading) {
        exit 1
      }

      start = 1
      end = count

      while (start <= end && lines[start] ~ /^[[:space:]]*$/) {
        start++
      }

      while (end >= start && lines[end] ~ /^[[:space:]]*$/) {
        end--
      }

      for (i = start; i <= end; i++) {
        print lines[i]
      }
    }
  ' "$wdid_file"
}

print_wdid_implementation_summary() {
  local wdid_file="$1"
  local summary

  [ -f "$wdid_file" ] || return 0

  if summary="$(extract_wdid_implementation_summary "$wdid_file")"; then
    printf '  Implementation Summary:\n'
    if [ -n "$summary" ]; then
      printf '%s\n' "$summary" | sed 's/^/    /'
    else
      printf '    (empty)\n'
    fi
  fi
}

print_wdid_implementation_summary_markdown() {
  local wdid_file="$1"
  local summary

  [ -f "$wdid_file" ] || return 0

  if summary="$(extract_wdid_implementation_summary "$wdid_file")"; then
    printf '\n**Implementation Summary**\n\n'
    if [ -n "$summary" ]; then
      printf '%s\n' "$summary"
    else
      printf '_(empty)_\n'
    fi
  fi
}

has_markdown_renderer() {
  command -v glow >/dev/null 2>&1 ||
    command -v mdcat >/dev/null 2>&1 ||
    command -v bat >/dev/null 2>&1
}

ensure_forkable_worktree() {
  local source="$1"
  local source_name="$2"

  [ -z "$(git -C "$source" ls-files -u)" ] ||
    die "cannot fork worktree '$source_name' with unresolved merge conflicts"
}

copy_uncommitted_changes() {
  local source="$1"
  local target="$2"
  local rel_path dest_path dest_dir
  local untracked_count=0

  if ! git -C "$source" diff --cached --quiet --no-ext-diff; then
    printf 'asdf: copying staged changes into %s\n' "$target" >&2
    git -C "$source" diff --cached --binary --no-ext-diff |
      git -C "$target" apply --index --whitespace=nowarn
  fi

  if ! git -C "$source" diff --quiet --no-ext-diff; then
    printf 'asdf: copying unstaged changes into %s\n' "$target" >&2
    git -C "$source" diff --binary --no-ext-diff |
      git -C "$target" apply --whitespace=nowarn
  fi

  while IFS= read -r -d '' rel_path; do
    dest_path="$target/$rel_path"
    dest_dir="$(dirname "$dest_path")"

    mkdir -p "$dest_dir"
    cp -p "$source/$rel_path" "$dest_path"
    untracked_count=$((untracked_count + 1))
  done < <(git -C "$source" ls-files --others --exclude-standard -z)

  printf 'asdf: copied %d untracked file(s) into %s\n' "$untracked_count" "$target" >&2
}

fork_worktree() {
  local source_name="$1"
  local target_name="$2"
  local source target existing source_head

  source="$(existing_workspace_path "$source_name")"
  validate_workspace_name "$target_name"

  [ "$target_name" != "local" ] ||
    die "cannot fork into local; choose a named worktree"

  existing="$(find_existing_worktree "$target_name")"
  [ -z "$existing" ] ||
    die "worktree '$target_name' already exists at $existing"

  [ ! -e "$WORKTREE_ROOT/$target_name" ] ||
    die "target '$WORKTREE_ROOT/$target_name' already exists but is not registered as a git worktree"

  if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$target_name"; then
    die "branch '$target_name' already exists"
  fi

  source_head="$(git -C "$source" rev-parse --verify HEAD 2>/dev/null)" ||
    die "could not resolve HEAD for worktree '$source_name'"
  ensure_forkable_worktree "$source" "$source_name"

  mkdir -p "$WORKTREE_ROOT"
  target="$WORKTREE_ROOT/$target_name"

  printf 'asdf: forking worktree %s into %s with new branch %s\n' "$source" "$target" "$target_name" >&2
  git -C "$REPO_ROOT" worktree add -b "$target_name" "$target" "$source_head" >&2
  copy_uncommitted_changes "$source" "$target"
  run_jkl "$source" "$target" "$target_name"
}

remove_worktree() {
  local name="$1"
  local existing

  validate_workspace_name "$name"

  [ "$name" != "local" ] ||
    die "refusing to remove the local checkout; provide a named worktree"

  existing="$(find_existing_worktree "$name")"
  [ -n "$existing" ] ||
    die "worktree '$name' was not found"

  [ "$existing" != "$PRIMARY_REPO_ROOT" ] ||
    die "refusing to remove the primary checkout; provide a named worktree"

  [ "$existing" != "$REPO_ROOT" ] ||
    die "refusing to remove the current checkout; run this from another checkout"

  printf 'asdf: removing worktree %s\n' "$existing" >&2
  git -C "$REPO_ROOT" worktree remove "$existing"
}

run_agent() {
  local bin="$1"
  local target="$2"

  command -v "$bin" >/dev/null 2>&1 || die "'$bin' command was not found in PATH"

  printf 'asdf: opening %s in %s\n' "$bin" "$target" >&2
  cd "$target" || exit 1
  if [ "${#agent_args[@]}" -gt 0 ]; then
    exec "$bin" "${agent_args[@]}"
  else
    exec "$bin"
  fi
}

enter_workspace() {
  local target="$1"
  local shell_bin="${SHELL:-/bin/sh}"

  if ! command -v "$shell_bin" >/dev/null 2>&1; then
    shell_bin="/bin/sh"
  fi

  printf 'asdf: entering %s\n' "$target" >&2
  cd "$target" || exit 1
  exec "$shell_bin"
}

wdid_prompt() {
  cat <<'EOF'
You are generating a worktree handoff summary.

Create a file named .wdid.md at the repository root. Do not modify any other file.

Goal: summarize what was done in this checkout/worktree so a developer returning later can quickly regain context.

Inspect the repository using read-only commands and file reads. Prefer:
- git status --short
- git status --branch --short
- git diff --stat
- git diff
- git diff --staged --stat
- git diff --staged
- git log --oneline --decorate --max-count=30
- branch/upstream/base comparisons when available

Do not run installs, builds, tests, or network calls unless absolutely necessary.

The .wdid.md file should be markdown with these sections:
# What Did I Do

## Snapshot
- Repository/worktree path
- Current branch
- Current HEAD
- Whether there are uncommitted changes

## Implementation Summary
- Bullet summary of the main work completed in this checkout
- Mention important files/modules only when helpful

## Git Changes
- Summarize unstaged, staged, and untracked changes
- Summarize commits unique to this branch when detectable

## How To Continue
- Concrete next steps a developer should take
- Mention obvious validation commands only if they are evident from the repo

Keep the file useful and scannable. Do not invent facts. If evidence is unclear, say so.
EOF
}

print_wdid_output_snippet() {
  local output_log="$1"

  printf 'asdf: captured output: %s\n' "$output_log" >&2

  if [ -s "$output_log" ]; then
    printf 'asdf: last 40 lines of captured output:\n' >&2
    tail -n 40 "$output_log" >&2 || true
  else
    printf 'asdf: captured output was empty\n' >&2
  fi
}

validate_generated_wdid() {
  local wdid_file="$1"
  local output_log="$2"

  if [ ! -f "$wdid_file" ]; then
    printf 'asdf: .wdid.md was not created at %s\n' "$wdid_file" >&2
    print_wdid_output_snippet "$output_log"
    exit 1
  fi

  if [ ! -s "$wdid_file" ]; then
    printf 'asdf: .wdid.md was created but is empty at %s\n' "$wdid_file" >&2
    print_wdid_output_snippet "$output_log"
    exit 1
  fi
}

run_codex_wdid() {
  local target="$1"
  local prompt="$2"

  if [ "${#agent_args[@]}" -gt 0 ]; then
    codex exec -C "$target" -s workspace-write "${agent_args[@]}" "$prompt" </dev/null
  else
    codex exec -C "$target" -s workspace-write "$prompt" </dev/null
  fi
}

run_claude_wdid() {
  local target="$1"
  local prompt="$2"

  if [ "${#agent_args[@]}" -gt 0 ]; then
    (cd "$target" && claude --print --permission-mode acceptEdits "${agent_args[@]}" "$prompt") </dev/null
  else
    (cd "$target" && claude --print --permission-mode acceptEdits "$prompt") </dev/null
  fi
}

generate_wdid() {
  local selected_agent="$1"
  local target="$2"
  local wdid_file="$3"
  local output_log prompt tmp_root

  command -v "$selected_agent" >/dev/null 2>&1 ||
    die "'$selected_agent' command was not found in PATH"

  tmp_root="${TMPDIR:-/tmp}"
  tmp_root="${tmp_root%/}"
  output_log="$(mktemp "$tmp_root/asdf-wdid.XXXXXX")" ||
    die "could not create temporary log file"
  prompt="$(wdid_prompt)"

  printf 'asdf: generating .wdid.md with %s in %s\n' "$selected_agent" "$target" >&2

  case "$selected_agent" in
    codex)
      if ! run_codex_wdid "$target" "$prompt" >"$output_log" 2>&1; then
        printf 'asdf: codex failed while generating .wdid.md\n' >&2
        print_wdid_output_snippet "$output_log"
        exit 1
      fi
      ;;
    claude)
      if ! run_claude_wdid "$target" "$prompt" >"$output_log" 2>&1; then
        printf 'asdf: claude failed while generating .wdid.md\n' >&2
        print_wdid_output_snippet "$output_log"
        exit 1
      fi
      ;;
    *)
      die "unsupported agent '$selected_agent'"
      ;;
  esac

  validate_generated_wdid "$wdid_file" "$output_log"
}

render_markdown_file() {
  local markdown_file="$1"
  local paging="${2:-always}"

  if [ ! -t 1 ]; then
    cat "$markdown_file"
    return
  fi

  if command -v glow >/dev/null 2>&1; then
    if [ "$paging" = "always" ]; then
      glow -p "$markdown_file"
    else
      glow "$markdown_file"
    fi
  elif command -v mdcat >/dev/null 2>&1; then
    mdcat "$markdown_file"
  elif command -v bat >/dev/null 2>&1; then
    bat --language markdown --style=plain --paging="$paging" "$markdown_file"
  elif [ "$paging" = "always" ] && command -v less >/dev/null 2>&1; then
    less -R "$markdown_file"
  else
    cat "$markdown_file"
  fi
}

render_wdid() {
  local wdid_file="$1"

  render_markdown_file "$wdid_file" always
}

case "${1:-}" in
  --version | version)
    shift || true
    [ "$#" -eq 0 ] || die "version does not accept extra arguments"
    print_version
    exit 0
    ;;
  update)
    shift
    asdf_update "$@"
    exit 0
    ;;
  --completion)
    shift
    print_completion_script "$@"
    exit 0
    ;;
  completion)
    shift
    print_completion_script "$@"
    exit 0
    ;;
  --complete)
    shift
    complete_asdf_words "$@"
    exit 0
    ;;
esac

maybe_warn_update_available "$@"

command_name="run"
current_dir="$(pwd -P)"
REPO_ROOT="$(git -C "$current_dir" rev-parse --show-toplevel 2>/dev/null)" ||
  die "run asdf from inside a git repository"
GIT_COMMON_DIR="$(git -C "$REPO_ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" ||
  die "could not resolve git common directory for $REPO_ROOT"

case "$(basename "$GIT_COMMON_DIR")" in
  .git) PRIMARY_REPO_ROOT="$(dirname "$GIT_COMMON_DIR")" ;;
  *) PRIMARY_REPO_ROOT="$REPO_ROOT" ;;
esac

repo_parent="$(dirname "$PRIMARY_REPO_ROOT")"
repo_name="$(basename "$PRIMARY_REPO_ROOT")"

if [ -n "${ASDF_WORKTREE_DIR:-}" ]; then
  case "$ASDF_WORKTREE_DIR" in
    /*) WORKTREE_ROOT="$ASDF_WORKTREE_DIR" ;;
    *) WORKTREE_ROOT="$REPO_ROOT/$ASDF_WORKTREE_DIR" ;;
  esac
else
  WORKTREE_ROOT="$repo_parent/${repo_name}-worktrees"
fi

parse_args "$@"

case "$command_name" in
  list)
    list_worktrees
    ;;
  run)
    target_dir="$(workspace_path "$workspace_name")"
    run_agent "$agent_name" "$target_dir"
    ;;
  cd)
    target_dir="$(workspace_path "$workspace_name")"
    enter_workspace "$target_dir"
    ;;
  rm)
    [ "$workspace_explicit" -eq 1 ] ||
      die "rm requires an explicit worktree name: asdf <worktree> rm"
    remove_worktree "$workspace_name"
    ;;
  fork)
    fork_worktree "$workspace_name" "$fork_workspace_name"
    ;;
  wdid)
    target_dir="$(workspace_path "$workspace_name")"
    wdid_file="$target_dir/.wdid.md"

    if [ -e "$wdid_file" ]; then
      [ -f "$wdid_file" ] ||
        die "$wdid_file exists but is not a regular file"
      render_wdid "$wdid_file"
      exit 0
    fi

    generate_wdid "$agent_name" "$target_dir" "$wdid_file"
    render_wdid "$wdid_file"
    ;;
  *)
    die "unknown command '$command_name'"
    ;;
esac
